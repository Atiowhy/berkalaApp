generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  name         String
  habits       Habit[]
  role         String?       @default("Pengguna")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  todos        Todo[]
  transactions Transaction[]
  savings      Saving[]
}

model Habit {
  id          String     @id @default(uuid())
  userId      String
  title       String
  description String?
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs        HabitLog[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
}

model HabitLog {
  id        String   @id @default(uuid())
  habitId   String
  date      DateTime @db.Date
  status    Status   @default(COMPLETED)
  notes     String?
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([habitId])
}

enum Status {
  COMPLETED
  SKIPPED
  FAILED
}

model Todo {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Tambahkan di bagian paling bawah schema.prisma
model Transaction {
  id          String   @id @default(uuid())
  userId      String
  type        String // Kita akan isi dengan "INCOME" atau "EXPENSE"
  amount      Int // Nominal uang (dalam Rupiah)
  category    String // Contoh: "Gaji", "Makanan", "Transportasi"
  description String? // Catatan opsional
  date        DateTime @default(now()) // Tanggal transaksi dilakukan
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Tambahkan di paling bawah
model Saving {
  id            String   @id @default(uuid())
  userId        String
  title         String // Nama impian: "Rakit PC Impian"
  targetAmount  Int // Target harga: 15.000.000
  currentAmount Int      @default(0) // Uang yang sudah masuk (mulai dari 0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
